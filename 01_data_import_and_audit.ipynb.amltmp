    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.metrics import classification_report\n",
        "\n",
        "# 1. Generate the classification report as a dictionary\n",
        "report_dict = classification_report(y_true, y_pred, output_dict=True)\n",
        "\n",
        "# 2. Convert to DataFrame and transpose for better table formatting\n",
        "df_report = pd.DataFrame(report_dict).transpose()\n",
        "\n",
        "# 3. Visualize as a Table Image\n",
        "plt.figure(figsize=(8, 4))\n",
        "# We use a heatmap with 'Blues' to display the table values clearly\n",
        "sns.heatmap(df_report, annot=True, cmap='Blues', fmt='.2f', cbar=False)\n",
        "\n",
        "plt.title('Classification Report: Model Performance')\n",
        "plt.yticks(rotation=0) \n",
        "\n",
        "# 4. Save the image\n",
        "save_path = os.path.join(output_dir, 'Classification-Report-Table.png')\n",
