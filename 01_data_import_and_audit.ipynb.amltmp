      "cell_type": "code",
      "source": [
        "from azure.ai.ml import MLClient\n",
        "from azure.identity import DefaultAzureCredential\n",
        "import pandas as pd\n",
        "\n",
        "def get_ml_client():\n",
        "    return MLClient.from_config(credential=DefaultAzureCredential())\n",
        "\n",
        "def load_data_from_asset(ml_client, data_name, version):\n",
        "    data_asset = ml_client.data.get(name=data_name, version=version)\n",
        "    return pd.read_csv(data_asset.path)\n",
        "\n",
        "def audit_data(df):\n",
        "    missing_values = df.isnull().sum()\n",
        "    return missing_values[missing_values > 0]"
      ],
      "outputs": [],
      "execution_count": 3,
      "metadata": {
        "gather": {
          "logged": 1781463947779
        }
      }
    },
