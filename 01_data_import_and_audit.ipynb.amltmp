        "# --- PART 2: ENVIRONMENT PREPARATION ---\n",
        "# Ensure necessary runtime libraries are present\n",
        "%pip install azureml-automl-runtime\n",
        "\n",
        "# --- PART 3: MODEL LOADING ---\n",
        "# Ensure your model URI points to the folder containing the 'MLmodel' file\n",
        "model_uri = \"icu-mortality-predictor/mlflow-model\"\n",
        "model = mlflow.sklearn.load_model(model_uri)\n",
        "print(\"Model loaded successfully using MLFlow!\")\n",
        "\n",
        "# --- PART 4: SCHEMA ALIGNMENT AND PREDICTION ---\n",
        "# 1. Extract the exact feature list the model expects\n",
        "expected_features = list(model.named_steps['datatransformer']._columns_types_mapping.keys())\n",
        "\n",
        "# 2. Check for alignment\n",
        "current_features = df.columns.tolist()\n",
        "missing_in_current = set(expected_features) - set(current_features)\n",
        "\n",
        "print(\"Columns missing from your current data (must be present):\", missing_in_current)\n",
        "\n",
        "# 3. Filter your DataFrame to match the model's required schema exactly\n",
        "# This ensures patient_id and other required features are included if they were in the training set\n",
        "X_corrected = df[expected_features]\n",
        "\n",
        "# 4. Run prediction\n",
        "df['mortality_predicted'] = model.predict(X_corrected)\n",
        "print(\"Predictions complete!\")"
      ],
