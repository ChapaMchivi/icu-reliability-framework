        "# --- PART 4: SCHEMA ALIGNMENT AND PREDICTION ---\n",
        "\n",
        "# Ensure the model exists; if not, try to load it\n",
        "if 'model' not in locals():\n",
        "    print(\"Model not found in memory. Please load your model first.\")\n",
        "    # Example: model = joblib.load('my_model_filename.pkl')\n",
        "else:\n",
        "    # 1. Extract the exact feature list the model expects\n",
        "    expected_features = list(model.named_steps['datatransformer']._columns_types_mapping.keys())\n",
        "\n",
        "    # 2. Check for alignment\n",
        "    current_features = df.columns.tolist()\n",
        "    missing_in_current = set(expected_features) - set(current_features)\n",
        "\n",
        "    # 3. IMPLEMENTED SAFETY GUARDRAIL: Hard-stop if schema does not align\n",
        "    if missing_in_current:\n",
        "        print(\"!!! SAFETY ALERT: SCHEMA MISMATCH DETECTED !!!\")\n",
        "        print(f\"Missing features required for safe inference: {missing_in_current}\")\n",
        "    else:\n",
        "        print(\"Schema alignment confirmed. Proceeding to inference...\")\n",
        "        X_corrected = df[expected_features]\n",
        "        df['mortality_predicted'] = model.predict(X_corrected)\n",
        "        print(\"Predictions complete!\")"
      ],
